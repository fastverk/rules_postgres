load("@rules_lean//lean:lean.bzl", "lean_test")
load("//tools/regen:cluster.bzl", "PG_IR_OLD_BASE", "PG_IR_PRELUDE", "gate1_cluster")

# Expose all Pg.* Lean source files publicly so cross-repo
# consumers (e.g. Aion's lean_test targets) can list them in
# their own `srcs` for shim-style migrations. rules_lean's
# lean_test rule doesn't expose a LeanInfo provider for
# downstream `deps` consumption, so cross-repo Lean source
# sharing happens at the source-file level via `srcs`.
exports_files(
    glob(["Pg/**/*.lean"]),
    visibility = ["//visibility:public"],
)

# ─── Gate 1 — regen idempotence (Bazel-native) ─────────────────────
#
# One `gate1_cluster(...)` per Pg.Ir cluster. The macro generates a
# `lean_emit` (Lean main → stdout) + a skylib `diff_test` (committed
# source vs lean_emit). Aggregated via `//tools/regen:gate1_all`.
#
# The src lists below mirror the per-cluster `lean -o Pg/Ir/...olean ...`
# sequences in `tools/regen/regen-*.sh`. Order matters — lean_emit
# compiles srcs sequentially.

# ── Clusters with the standard PG_IR_OLD_BASE prelude (Types, Datum,
# Cmp, Emit/Common) plus their <Cluster>Common module. Rust-only emit. ──

gate1_cluster(
    name = "int_arith",
    rust_entry = "Pg/Ir/Emit/IntArith.lean",
    rust_target = "//rust/pg_int4_arith:lib_rs",
    srcs = PG_IR_OLD_BASE + [
        "Pg/Ir/Emit/IntArithCommon.lean",
        "Pg/Ir/Emit/IntArith.lean",
    ],
)

gate1_cluster(
